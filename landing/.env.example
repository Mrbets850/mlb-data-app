# ─── Stripe ───────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Price ID for the $4.99/month subscription plan.
# Create this in Stripe Dashboard → Products → Add Product → Recurring → $4.99/month
# Then copy the price ID (starts with "price_")
STRIPE_PRICE_ID=price_...

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# For local dev, use the Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ──────────────────────────────────────────────
# Base URL of this landing page (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Access Code ──────────────────────────────────────
# Access code shown on the success page after payment.
# Must match ACCESS_CODE set in your Railway environment.
ACCESS_CODE=EDGE2026
